{% extends 'layout/app.html.twig' %}

{% block page_title %}Gestion des comptes{% endblock %}

{% block content %}
<div class="d-flex justify-content-end mb-3">
    <a href="{{ url('user_form') }}" class="btn btn-primary">
        <i class="fa-solid fa-user-plus"></i> Ajouter un compte
    </a>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.username }}</td>
                        <td><span class="badge bg-primary">{{ role_label(user.role) }}</span></td>
                        <td>
                            <a href="{{ url('user_form', {id: user.id}) }}" class="btn btn-sm btn-warning">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            {% if user.id != app_user.id %}
                                <a href="{{ url('user_delete', {id: user.id}) }}" class="btn btn-sm btn-danger"
                                   onclick="return confirm('Supprimer ce compte ?');">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block body %}
<div class="app-shell d-flex">
    <aside class="sidebar d-flex flex-column">
        <div class="brand">
            <i class="fa-solid fa-graduation-cap me-2"></i>Student Manager
        </div>
        <nav class="flex-grow-1 py-2">
            <div class="nav-section">Principal</div>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('home') ? 'active' : '' }}" href="{{ url('home') }}">
                <i class="fa-solid fa-house"></i> Accueil
            </a>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('dashboard') ? 'active' : '' }}" href="{{ url('dashboard') }}">
                <i class="fa-solid fa-gauge-high"></i> Tableau de bord
            </a>

            <div class="nav-section mt-2">Gestion</div>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('students') ? 'active' : '' }}" href="{{ url('students_list') }}">
                <i class="fa-solid fa-user-graduate"></i> Etudiants
            </a>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('sections') ? 'active' : '' }}" href="{{ url('sections_list') }}">
                <i class="fa-solid fa-layer-group"></i> Sections
            </a>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('announcements') ? 'active' : '' }}" href="{{ url('announcements_list') }}">
                <i class="fa-solid fa-bullhorn"></i> Annonces
            </a>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('statistics') ? 'active' : '' }}" href="{{ url('statistics') }}">
                <i class="fa-solid fa-chart-column"></i> Statistiques
            </a>

            {% if is_super_admin() %}
            <div class="nav-section mt-2">Administration</div>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('users') ? 'active' : '' }}" href="{{ url('users_list') }}">
                <i class="fa-solid fa-users-gear"></i> Comptes
            </a>
            {% endif %}

            <div class="nav-section mt-2">Compte</div>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('profile') ? 'active' : '' }}" href="{{ url('profile') }}">
                <i class="fa-solid fa-id-card"></i> Mon profil
            </a>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('help') ? 'active' : '' }}" href="{{ url('help') }}">
                <i class="fa-solid fa-circle-question"></i> Aide
            </a>
            <a class="nav-link d-flex align-items-center gap-2 {{ route_active('about') ? 'active' : '' }}" href="{{ url('about') }}">
                <i class="fa-solid fa-circle-info"></i> A propos
            </a>
        </nav>
        <div class="p-3 border-top border-secondary">
            <div class="small text-secondary mb-2">
                <i class="fa-solid fa-user me-1"></i>
                {{ app_user.username }}<br>
                <span class="badge bg-primary mt-1">{{ role_label(app_user.role) }}</span>
            </div>
            <a href="{{ url('logout') }}" class="btn btn-outline-light btn-sm w-100">
                <i class="fa-solid fa-right-from-bracket"></i> Deconnexion
            </a>
        </div>
    </aside>
    <main class="main-content">
        <div class="topbar d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">{% block page_title %}Student Manager{% endblock %}</h5>
                {% block page_subtitle %}{% endblock %}
            </div>
            <div class="text-muted small">{% block page_meta %}{% endblock %}</div>
        </div>
        {% block content %}{% endblock %}
    </main>
</div>
{% endblock %}

{% extends 'layout/app.html.twig' %}

{% block page_title %}{{ isEdit ? 'Modifier' : 'Publier' }} une annonce{% endblock %}

{% block content %}
<div class="card shadow-sm">
    <div class="card-body">
        {% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Titre</label>
                <input type="text" name="title" class="form-control" value="{{ announcement.title }}" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Contenu</label>
                <textarea name="content" class="form-control" rows="6" required>{{ announcement.content }}</textarea>
            </div>
            <button class="btn btn-success" type="submit">Enregistrer</button>
            <a href="{{ url('announcements_list') }}" class="btn btn-secondary">Annuler</a>
        </form>
    </div>
</div>
{% endblock %}

{% extends 'layout/app.html.twig' %}

{% block page_title %}Annonces{% endblock %}

{% block content %}
<div class="d-flex justify-content-end mb-3">
    {% if is_teacher() %}
        <a href="{{ url('announcement_form') }}" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Nouvelle annonce
        </a>
    {% endif %}
</div>

<div class="row g-3">
    {% for announcement in announcements %}
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="mb-1">{{ announcement.title }}</h5>
                            <small class="text-muted">
                                {{ announcement.createdAt|date('d/m/Y H:i') }}
                                {% if announcement.author %}
                                    — par {{ announcement.author.username }}
                                {% endif %}
                            </small>
                        </div>
                        {% if is_teacher() %}
                            <div>
                                <a href="{{ url('announcement_form', {id: announcement.id}) }}" class="btn btn-sm btn-warning">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a href="{{ url('announcement_delete', {id: announcement.id}) }}" class="btn btn-sm btn-danger"
                                   onclick="return confirm('Supprimer cette annonce ?');">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        {% endif %}
                    </div>
                    <p class="mt-2 mb-0">{{ announcement.content|nl2br }}</p>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">Aucune annonce publiee.</div>
        </div>
    {% endfor %}
</div>
{% endblock %}

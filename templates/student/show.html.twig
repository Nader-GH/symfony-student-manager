{% extends 'layout/app.html.twig' %}

{% block page_title %}Fiche etudiant{% endblock %}

{% block content %}
<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                {% if student.image %}
                    <img src="{{ student.image }}" alt="{{ student.nom }}" class="img-fluid rounded mb-3" style="max-height: 220px;">
                {% else %}
                    <div class="bg-light rounded py-5 mb-3 text-muted">
                        <i class="fa-solid fa-user fa-4x"></i>
                    </div>
                {% endif %}
                <h4>{{ student.nom }}</h4>
                <span class="badge bg-secondary">{{ student.section.designation }}</span>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">{{ student.id }}</dd>
                    <dt class="col-sm-4">Date de naissance</dt>
                    <dd class="col-sm-8">{{ student.dateNaissance|date('d/m/Y') }}</dd>
                    <dt class="col-sm-4">Age</dt>
                    <dd class="col-sm-8">{{ student.age }} ans</dd>
                    <dt class="col-sm-4">Section</dt>
                    <dd class="col-sm-8">{{ student.section.designation }} — {{ student.section.description }}</dd>
                </dl>
                <div class="mt-3">
                    <a href="{{ url('students_list', {section_id: student.section.id}) }}" class="btn btn-outline-info btn-sm">
                        Voir la section
                    </a>
                    {% if is_teacher() %}
                        <a href="{{ url('student_form', {id: student.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                    {% endif %}
                    <a href="{{ url('students_list') }}" class="btn btn-secondary btn-sm">Retour</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'layout/app.html.twig' %}

{% block page_title %}Gestion des etudiants{% endblock %}

{% block content %}
<form method="get" action="{{ url('students_list') }}" class="row g-2 mb-3 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Section</label>
        <select name="section_id" class="form-select">
            <option value="0" {{ sectionId == 0 ? 'selected' : '' }}>Toutes les sections</option>
            {% for section in sections %}
                <option value="{{ section.id }}" {{ sectionId == section.id ? 'selected' : '' }}>
                    {{ section.designation }}
                </option>
            {% endfor %}
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filtrer</button>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        {% if sectionId > 0 %}
            <span class="badge bg-info">Filtre section #{{ sectionId }}</span>
            <a href="{{ url('students_list') }}" class="btn btn-sm btn-link">Tout afficher</a>
        {% endif %}
    </div>
    {% if is_teacher() %}
        <a href="{{ url('student_form') }}" class="btn btn-primary">
            <i class="fa-solid fa-user-plus"></i> Ajouter un etudiant
        </a>
    {% endif %}
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row g-2 mb-3">
            <div class="col-md-4">
                <input type="text" id="customFilter" class="form-control" placeholder="Filtrer...">
            </div>
            <div class="col-auto">
                <button id="customFilterBtn" class="btn btn-danger">Filtrer</button>
            </div>
        </div>

        <table id="studentsTable" class="display table table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Image</th>
                    <th>Nom</th>
                    <th>Naissance</th>
                    <th>Age</th>
                    <th>Section</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for student in students %}
                    <tr>
                        <td>{{ student.id }}</td>
                        <td>
                            {% if student.image %}
                                <img src="{{ student.image }}" alt="photo" class="table-avatar">
                            {% else %}
                                <span class="text-muted">N/A</span>
                            {% endif %}
                        </td>
                        <td>{{ student.nom }}</td>
                        <td>{{ student.dateNaissance|date('d/m/Y') }}</td>
                        <td>{{ student.age }} ans</td>
                        <td>{{ student.section.designation }}</td>
                        <td>
                            <a href="{{ url('student_show', {id: student.id}) }}" class="btn btn-sm btn-info" title="Voir">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            {% if is_teacher() %}
                                <a href="{{ url('student_form', {id: student.id}) }}" class="btn btn-sm btn-warning" title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a href="{{ url('student_delete', {id: student.id}) }}" class="btn btn-sm btn-danger" title="Delete"
                                   onclick="return confirm('Supprimer cet etudiant ?');">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(function () {
    const table = $('#studentsTable').DataTable({
        dom: 'Bfrtip',
        buttons: ['copy', 'excel', 'csv', 'pdf'],
        pageLength: 5
    });
    $('#customFilterBtn').on('click', function () {
        table.search($('#customFilter').val()).draw();
    });
});
</script>
{% endblock %}

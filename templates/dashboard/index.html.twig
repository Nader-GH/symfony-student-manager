{% extends 'layout/app.html.twig' %}

{% block page_title %}Tableau de bord{% endblock %}
{% block page_subtitle %}<small class="text-muted">Vue d'ensemble de l'etablissement</small>{% endblock %}

{% block content %}
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small opacity-75">Etudiants</div>
                        <div class="fs-3 fw-bold">{{ stats.students }}</div>
                    </div>
                    <i class="fa-solid fa-user-graduate fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small opacity-75">Sections</div>
                        <div class="fs-3 fw-bold">{{ stats.sections }}</div>
                    </div>
                    <i class="fa-solid fa-layer-group fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small opacity-75">Annonces</div>
                        <div class="fs-3 fw-bold">{{ stats.announcements }}</div>
                    </div>
                    <i class="fa-solid fa-bullhorn fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card text-bg-dark">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small opacity-75">Comptes</div>
                        <div class="fs-3 fw-bold">{{ stats.users }}</div>
                    </div>
                    <i class="fa-solid fa-users fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Dernieres annonces</span>
        <a href="{{ url('announcements_list') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
    </div>
    <div class="card-body">
        {% if recentAnnouncements is empty %}
            <p class="text-muted mb-0">Aucune annonce pour le moment.</p>
        {% else %}
            <div class="list-group list-group-flush">
                {% for item in recentAnnouncements %}
                    <div class="list-group-item px-0">
                        <div class="fw-semibold">{{ item.title }}</div>
                        <div class="small text-muted">{{ item.createdAt|date('d/m/Y H:i') }}</div>
                        <p class="mb-0 mt-1">{{ item.content|length > 120 ? item.content|slice(0, 120) ~ '...' : item.content }}</p>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
